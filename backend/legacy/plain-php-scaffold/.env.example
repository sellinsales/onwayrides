APP_NAME=OnWayRides
APP_ENV=production
APP_URL=https://onwayrides.com
APP_DEBUG=false
APP_TIMEZONE=UTC

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=onwayrides_onwayrides
DB_USERNAME=onwayrides_onway
DB_PASSWORD=change_me

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
FIREBASE_WEB_API_KEY=replace_me
FIREBASE_APP_ID=replace_me
FIREBASE_MESSAGING_SENDER_ID=replace_me
FIREBASE_STORAGE_BUCKET=replace_me

MAPS_PROVIDER=google
MAPS_API_KEY=replace_me

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=replace_me
MAIL_PASSWORD=replace_me
MAIL_ENCRYPTION=tls
MAIL_FROM_NAME="OnWay Rides"
MAIL_FROM_ADDRESS=support@onwayrides.com
SUPPORT_EMAIL=support@onwayrides.com
SUPPORT_PHONE=+92-300-0000000

CORS_ALLOWED_ORIGINS=https://onwayrides.com,https://www.onwayrides.com,http://localhost:3000
UPLOAD_DIR=storage/uploads

CASH_PAYMENTS_ENABLED=true
WALLET_PAYMENTS_ENABLED=false
CARD_PAYMENTS_ENABLED=false
